---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: import('astro').ImageMetadata;
	pillar?: string;
}

const { title, description, pubDate, updatedDate, heroImage, pillar } = Astro.props;
---

<html lang="pt-BR">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 100%;
				max-width: 1020px;
				margin: 1.5em auto 0;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--text);
			}
			.title {
				margin-bottom: 1em;
				padding: 1.5em 0 1em;
				line-height: 1.1;
			}
			.title h1 {
				margin: 0.3em 0 0.4em 0;
			}
			.meta {
				color: var(--muted);
				font-size: 0.9em;
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)
				}
				<div class="prose">
					<div class="title">
						{pillar && <span class="pilar-badge">{pillar}</span>}
						<h1>{title}</h1>
						<div class="meta">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<span class="last-updated-on"> · atualizado em <FormattedDate date={updatedDate} /></span>
								)
							}
						</div>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
