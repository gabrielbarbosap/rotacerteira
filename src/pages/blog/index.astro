---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (
	await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = `Blog — ${SITE_TITLE}`;
const description = 'Todos os artigos do Rota Certeira.';
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Blog</h1>
			{
				posts.length === 0 ? (
					<p>Os primeiros artigos estão a caminho. Volte em breve.</p>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="pilar-badge">{post.data.pillar}</span>
									<span class="t">{post.data.title}</span>
									<span class="d">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />
	</body>
</html>
<style>
	.post-list {
		list-style: none;
		padding: 0;
		margin: 1.5em 0;
		display: flex;
		flex-direction: column;
		gap: 0.6em;
	}
	.post-list li a {
		display: flex;
		align-items: center;
		gap: 0.8em;
		padding: 0.8em 1em;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 10px;
		text-decoration: none;
		color: var(--text);
	}
	.post-list li a:hover {
		border-color: var(--accent);
	}
	.post-list .t {
		font-weight: 600;
		flex: 1;
	}
	.post-list .d {
		color: var(--muted);
		font-size: 0.85em;
		white-space: nowrap;
	}
	@media (max-width: 720px) {
		.post-list li a {
			flex-wrap: wrap;
			gap: 0.4em;
		}
	}
</style>
