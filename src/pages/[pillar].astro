---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, PILLARS } from '../consts';

export async function getStaticPaths() {
	return PILLARS.map((p) => ({ params: { pillar: p.slug }, props: p }));
}

const { slug, label } = Astro.props;
const posts = (
	await getCollection('blog', ({ data }) =>
		data.pillar === slug && (import.meta.env.PROD ? !data.draft : true),
	)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = `${label} — ${SITE_TITLE}`;
const description = `Artigos do pilar ${label} no ${SITE_TITLE}.`;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{label}</h1>
			{
				posts.length === 0 ? (
					<p>Ainda não há artigos publicados neste pilar. Volte em breve.</p>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="t">{post.data.title}</span>
									<span class="d">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />
	</body>
</html>
<style>
	.post-list {
		list-style: none;
		padding: 0;
		margin: 1.5em 0;
		display: flex;
		flex-direction: column;
		gap: 0.6em;
	}
	.post-list li a {
		display: flex;
		align-items: center;
		gap: 0.8em;
		padding: 0.8em 1em;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 10px;
		text-decoration: none;
		color: var(--text);
	}
	.post-list li a:hover {
		border-color: var(--accent);
	}
	.post-list .t {
		font-weight: 600;
		flex: 1;
	}
	.post-list .d {
		color: var(--muted);
		font-size: 0.85em;
		white-space: nowrap;
	}
</style>
