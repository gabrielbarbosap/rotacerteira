---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, PILLARS } from '../consts';

const all = (
	await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = all[0];
const mostRead = all.slice(1, 6);
const recent = all.slice(1);

const pillarLabel = (slug: string) => PILLARS.find((p) => p.slug === slug)?.label ?? slug;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			{
				featured && (
					<section class="home-hero">
						<div class="hero-main">
							<ArticleCard post={featured} featured />
						</div>
						<aside class="mais-lidas">
							<h2>Mais lidas</h2>
							<ol>
								{mostRead.map((post) => (
									<li>
										<a href={`/blog/${post.id}/`}>
											<span class="ml-pill">{pillarLabel(post.data.pillar)}</span>
											<span class="ml-title">{post.data.title}</span>
										</a>
									</li>
								))}
							</ol>
						</aside>
					</section>
				)
			}

			<nav class="pillar-chips" aria-label="Pilares">
				{PILLARS.map((p) => <a href={`/${p.slug}`}>{p.label}</a>)}
			</nav>

			<section class="recent">
				<h2 class="section-title">Mais recentes</h2>
				{
					recent.length > 0 ? (
						<div class="card-grid">
							{recent.map((post) => (
								<ArticleCard post={post} />
							))}
						</div>
					) : (
						<p>Os próximos artigos estão a caminho. Volte em breve.</p>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		width: 1120px;
		max-width: calc(100% - 2em);
	}
	.home-hero {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5em;
		margin-top: 1.5em;
	}
	.mais-lidas {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.2em 1.3em;
	}
	.mais-lidas h2 {
		font-size: 1.1rem;
		margin: 0 0 0.6em;
		padding-bottom: 0.5em;
		border-bottom: 2px solid var(--accent);
	}
	.mais-lidas ol {
		margin: 0;
		padding: 0;
		list-style: none;
		counter-reset: ml;
	}
	.mais-lidas li {
		counter-increment: ml;
		border-bottom: 1px solid var(--border);
	}
	.mais-lidas li:last-child {
		border-bottom: none;
	}
	.mais-lidas li a {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.2em 0.7em;
		align-items: start;
		padding: 0.7em 0;
		text-decoration: none;
	}
	.mais-lidas li a::before {
		content: counter(ml);
		grid-row: 1 / span 2;
		font-family: var(--font-heading), Georgia, serif;
		font-weight: 700;
		font-size: 1.4rem;
		color: var(--accent);
		line-height: 1;
		min-width: 1ch;
	}
	.ml-pill {
		font: 700 0.6rem/1 var(--font-body), sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.4px;
		color: var(--link);
	}
	.ml-title {
		color: var(--heading);
		font-weight: 600;
		font-size: 0.95rem;
		line-height: 1.3;
	}
	.mais-lidas li a:hover .ml-title {
		color: var(--link);
	}
	.pillar-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin: 2em 0 1.5em;
	}
	.pillar-chips a {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.4em 0.9em;
		text-decoration: none;
		color: var(--text);
		font-size: 0.9rem;
	}
	.pillar-chips a:hover {
		border-color: var(--accent);
		color: var(--link);
	}
	@media (min-width: 900px) {
		.home-hero {
			grid-template-columns: 2fr 1fr;
		}
	}
</style>
