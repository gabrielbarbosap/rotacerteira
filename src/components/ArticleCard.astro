---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { PILLARS } from '../consts';

interface Props {
	post: CollectionEntry<'blog'>;
	featured?: boolean;
}

const { post, featured = false } = Astro.props;
const pillarLabel = PILLARS.find((p) => p.slug === post.data.pillar)?.label ?? post.data.pillar;
const href = `/blog/${post.id}/`;
---

<article class:list={['card', { featured }]}>
	<a class="thumb" href={href} data-pillar={post.data.pillar} aria-hidden="true" tabindex="-1">
		{
			post.data.heroImage ? (
				<Image
					src={post.data.heroImage}
					width={featured ? 900 : 460}
					height={featured ? 506 : 259}
					alt=""
				/>
			) : (
				<span class="thumb-ph">{pillarLabel}</span>
			)
		}
	</a>
	<div class="body">
		<a class="pill" href={`/${post.data.pillar}`}>{pillarLabel}</a>
		<a class="title" href={href}>
			<h3>{post.data.title}</h3>
		</a>
		{featured && <p class="excerpt">{post.data.description}</p>}
		<span class="date"><FormattedDate date={post.data.pubDate} /></span>
	</div>
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 12px;
		overflow: hidden;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.card:hover {
		transform: translateY(-2px);
		box-shadow: var(--box-shadow);
	}
	.thumb {
		display: block;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		position: relative;
	}
	.thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
	}
	.thumb-ph {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #0f2a43, #1e5a8a);
		color: rgba(255, 255, 255, 0.85);
		font-family: var(--font-heading), Georgia, serif;
		font-weight: 700;
		font-size: 1.1rem;
		letter-spacing: 0.5px;
	}
	.thumb-ph::after {
		content: '';
		position: absolute;
		right: 14px;
		bottom: 12px;
		width: 34px;
		height: 4px;
		background: var(--accent);
		border-radius: 2px;
	}
	.body {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
		padding: 0.9em 1em 1.1em;
	}
	.pill {
		align-self: flex-start;
		background: var(--accent);
		color: var(--accent-ink);
		font: 700 0.65rem/1 var(--font-body), sans-serif;
		letter-spacing: 0.4px;
		text-transform: uppercase;
		padding: 0.35em 0.7em;
		border-radius: 999px;
		text-decoration: none;
	}
	.title {
		text-decoration: none;
	}
	.title h3 {
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.25;
		color: var(--heading);
	}
	.card:hover .title h3 {
		color: var(--link);
	}
	.excerpt {
		margin: 0;
		color: var(--muted);
		font-size: 0.95rem;
	}
	.date {
		color: var(--muted);
		font-size: 0.8rem;
	}

	/* Variante em destaque (herói) */
	.card.featured .thumb {
		aspect-ratio: 16 / 8;
	}
	.card.featured .title h3 {
		font-size: 1.7rem;
	}
	@media (min-width: 720px) {
		.card.featured {
			flex-direction: row;
		}
		.card.featured .thumb {
			flex: 1 1 55%;
			aspect-ratio: auto;
		}
		.card.featured .body {
			flex: 1 1 45%;
			justify-content: center;
			padding: 1.6em;
		}
		.card.featured .title h3 {
			font-size: 2rem;
		}
	}
</style>
